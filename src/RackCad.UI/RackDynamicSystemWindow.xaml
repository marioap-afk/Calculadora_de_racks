<Window x:Class="RackCad.UI.RackDynamicSystemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema dinámico (Pallet Flow) - vista lateral preliminar"
        Height="700"
        Width="1180"
        MinHeight="540"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F6"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#415161" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,8,0,3" />
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#C9D2DD" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2933" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>

        <!-- Accent button for the main call to action. -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2B6CB0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2C5282" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#234876" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#A0AEC0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Subtle outlined button for secondary actions. -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#2D3748" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#C9D2DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EDF2F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E2E8F0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: inputs + module table + properties -->
        <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Tarima" Style="{StaticResource SectionTitle}" Margin="0,0,0,2" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Frente (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="FrontBox" Style="{StaticResource FieldBox}" Text="42" />
                            <TextBlock Text="Altura tarima (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="PalletHeightBox" Style="{StaticResource FieldBox}" Text="60" />
                            <TextBlock Text="Tarimas de fondo" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="PalletsDeepBox" Style="{StaticResource FieldBox}" Text="8" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Fondo (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="DepthBox" Style="{StaticResource FieldBox}" Text="48" />
                            <TextBlock Text="Peso (kg)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="WeightBox" Style="{StaticResource FieldBox}" Text="1000" />
                        </StackPanel>
                    </Grid>

                    <Button Content="Actualizar vista (recalcular)" Click="Update_Click" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,12,0,0" />

                    <TextBlock Text="Módulos" Style="{StaticResource SectionTitle}" />
                    <DataGrid x:Name="ModulesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              Height="190"
                              BorderBrush="#D8DEE6"
                              BorderThickness="1"
                              SelectionChanged="ModulesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="32" />
                            <DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="*" />
                            <DataGridTextColumn Header="Long" Binding="{Binding Length, StringFormat={}{0:0.##}}" Width="55" />
                            <DataGridTextColumn Header="X0" Binding="{Binding StartX, StringFormat={}{0:0.##}}" Width="55" />
                            <DataGridTextColumn Header="Ovr" Binding="{Binding IsManualOverride}" Width="40" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#F1F4F8" BorderBrush="#D8DEE6" BorderThickness="1" Padding="10" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Módulo seleccionado" FontWeight="SemiBold" Foreground="#415161" FontSize="12" />
                            <TextBlock x:Name="SelectedInfoText" Foreground="#617080" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" />

                            <TextBlock Text="Tipo" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="KindBox" />

                            <TextBlock Text="Longitud (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="ModuleLengthBox" Style="{StaticResource FieldBox}" />

                            <WrapPanel Margin="0,10,0,0">
                                <Button x:Name="ApplyModuleButton" Content="Aplicar" Click="ApplyModule_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" IsEnabled="False" />
                                <Button x:Name="EditHeaderButton" Content="Editar cabecera" Click="EditHeader_Click" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="SummaryText" Foreground="#1F2933" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0" />
                    <TextBlock x:Name="StatusText" Foreground="#617080" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right: side view -->
        <Border Grid.Row="0" Grid.Column="2" Background="White" BorderBrush="#D8DEE6" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="10,8">
                    <TextBlock Text="Vista lateral (X = longitud del sistema, Y = altura de cabecera). Clic en un módulo para seleccionarlo."
                               Foreground="#617080" FontSize="11" TextWrapping="Wrap" />
                    <WrapPanel Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="16" Height="8" Background="#335B78" BorderBrush="#7DA4BF" BorderThickness="1" Margin="0,3,5,0" />
                            <TextBlock Text="cabecera" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="16" Height="1" Background="#8AA0B4" Margin="0,7,5,0" />
                            <TextBlock Text="separador" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="2" Height="12" Background="#FF6B6B" Margin="7,1,5,0" />
                            <TextBlock Text="poste derivado" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="3" Height="12" Background="#F2A63B" Margin="7,1,5,0" />
                            <TextBlock Text="refuerzo" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="16" Height="8" BorderBrush="#FFD166" BorderThickness="2" Margin="0,3,5,0" />
                            <TextBlock Text="selección" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
                <Canvas x:Name="PreviewCanvas" Grid.Row="1" Background="#0E1B2A" ClipToBounds="True"
                        SizeChanged="PreviewCanvas_SizeChanged" MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown" />
            </Grid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Restaurar layout predeterminado" Style="{StaticResource SecondaryButtonStyle}" MinWidth="210" Margin="0,0,8,0"
                    ToolTip="Recalcula el sistema desde la tarima y elimina los overrides manuales." Click="RestoreDefault_Click" />
            <Button Content="Exportar BOM" Style="{StaticResource SecondaryButtonStyle}" MinWidth="120" Margin="0,0,8,0" Click="ExportBom_Click" />
            <Button Content="Ver BOM" Style="{StaticResource SecondaryButtonStyle}" MinWidth="100" Margin="0,0,8,0" Click="ViewBom_Click" />
            <Button Content="Abrir sistema" Style="{StaticResource SecondaryButtonStyle}" MinWidth="120" Margin="0,0,8,0" Click="OpenSystem_Click" />
            <Button Content="Guardar sistema" Style="{StaticResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,0" Click="SaveSystem_Click" />
            <Button Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
