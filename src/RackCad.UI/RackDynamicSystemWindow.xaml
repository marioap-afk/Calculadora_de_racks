<Window x:Class="RackCad.UI.RackDynamicSystemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema dinamico (Pallet Flow) - vista lateral preliminar"
        Height="620"
        Width="980"
        MinHeight="460"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F9">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#415161" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,8,0,3" />
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#C9D2DD" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Inputs -->
        <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Tarima" FontWeight="SemiBold" Foreground="#1F2933" FontSize="14" />

                    <TextBlock Text="Frente (in)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="FrontBox" Style="{StaticResource FieldBox}" Text="42" />

                    <TextBlock Text="Fondo (in)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="DepthBox" Style="{StaticResource FieldBox}" Text="48" />

                    <TextBlock Text="Altura de tarima (in)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="PalletHeightBox" Style="{StaticResource FieldBox}" Text="60" />

                    <TextBlock Text="Peso (kg)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="WeightBox" Style="{StaticResource FieldBox}" Text="1000" />

                    <TextBlock Text="Tarimas de fondo" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="PalletsDeepBox" Style="{StaticResource FieldBox}" Text="8" />

                    <TextBlock Text="Profundidad de cabecera (in, opcional)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="HeaderDepthOverrideBox" Style="{StaticResource FieldBox}" Text=""
                             ToolTip="Vacio = fondo + 6 (derivado). Escribe un valor para sobrescribir." />

                    <Button Content="Actualizar vista" Click="Update_Click" Margin="0,16,0,0" Padding="12,7" />

                    <Border Background="#F1F4F8" BorderBrush="#D8DEE6" BorderThickness="1" Padding="10" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Cabecera (componente)" FontWeight="SemiBold" Foreground="#415161" FontSize="12" />
                            <TextBlock x:Name="HeaderInfoText" Foreground="#617080" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="SummaryText" Foreground="#1F2933" FontSize="12" TextWrapping="Wrap" Margin="0,14,0,0" />
                    <TextBlock x:Name="StatusText" Foreground="#617080" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Side view -->
        <Border Grid.Row="0" Grid.Column="2" Background="White" BorderBrush="#D8DEE6" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Vista lateral (X = longitud del sistema, Y = altura de cabecera)"
                           Foreground="#617080" FontSize="11" Margin="10,8" />
                <Canvas x:Name="PreviewCanvas" Grid.Row="1" Background="#0E1B2A" ClipToBounds="True"
                        SizeChanged="PreviewCanvas_SizeChanged" />
            </Grid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Exportar BOM" MinWidth="120" Padding="14,7" Margin="0,0,8,0" Click="ExportBom_Click" />
            <Button Content="Ver BOM" MinWidth="100" Padding="14,7" Margin="0,0,8,0" Click="ViewBom_Click" />
            <Button Content="Abrir sistema" MinWidth="120" Padding="14,7" Margin="0,0,8,0" Click="OpenSystem_Click" />
            <Button Content="Guardar sistema" MinWidth="130" Padding="14,7" Margin="0,0,8,0" Click="SaveSystem_Click" />
            <Button Content="Cerrar" MinWidth="90" Padding="14,7" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
