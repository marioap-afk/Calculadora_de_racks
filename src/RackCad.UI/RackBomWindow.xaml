<Window x:Class="RackCad.UI.RackBomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lista de materiales (preliminar)"
        Height="520"
        Width="740"
        MinHeight="320"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Lista de materiales preliminar"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <TextBlock x:Name="SummaryText"
                       Foreground="#617080"
                       FontSize="12"
                       Margin="0,4,0,0" />
            <TextBlock Text="Vista preliminar derivada del modelo. Longitudes y agrupacion se refinaran mas adelante."
                       Foreground="#9AA7B4"
                       FontSize="11"
                       Margin="0,2,0,0" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  x:Name="BomGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowBackground="White"
                  AlternatingRowBackground="#F7F9FB"
                  BorderBrush="#D8DEE6"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="110" />
                <DataGridTextColumn Header="Perfil" Binding="{Binding ProfileId}" Width="210" />
                <DataGridTextColumn Header="Descripcion" Binding="{Binding Description}" Width="*" />
                <DataGridTextColumn Header="Longitud (in)" Binding="{Binding Length, StringFormat={}{0:0.##}}" Width="105" />
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Quantity}" Width="85" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Exportar CSV"
                    MinWidth="120"
                    Padding="14,7"
                    Margin="0,0,8,0"
                    Click="ExportCsv_Click" />
            <Button Content="Cerrar"
                    MinWidth="90"
                    Padding="14,7"
                    Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
