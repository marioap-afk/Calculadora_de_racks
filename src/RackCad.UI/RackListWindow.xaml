<Window x:Class="RackCad.UI.RackListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Racks del dibujo"
        Height="480"
        Width="720"
        MinHeight="320"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RackCad.UI;component/Themes/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Racks del dibujo" FontSize="18" FontWeight="SemiBold" Foreground="#1F2933" />
            <TextBlock Text="Todos los racks encontrados en el dibujo actual. «Ir al rack» hace zoom a su primera copia."
                       Foreground="#617080" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  x:Name="RacksGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowBackground="White"
                  AlternatingRowBackground="#F7F9FB"
                  BorderBrush="#D8DEE6"
                  BorderThickness="1"
                  SelectionMode="Single"
                  MouseDoubleClick="RacksGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Tipo" Binding="{Binding KindLabel}" Width="150" />
                <DataGridTextColumn Header="Vistas" Binding="{Binding ViewsLabel}" Width="180" />
                <DataGridTextColumn Header="Copias" Binding="{Binding CopiesCount}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,8,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#617080" FontSize="11.5" Margin="0,0,12,0" />
            <Button Content="Ir al rack" Style="{StaticResource PrimaryButtonStyle}" MinWidth="110" Margin="0,0,8,0" Click="GoTo_Click" IsDefault="True" />
            <Button Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" Click="Close_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
