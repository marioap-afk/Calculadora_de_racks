<Window x:Class="RackCad.UI.RackLargueroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Larguero (componente)"
        Height="440"
        Width="720"
        MinHeight="380"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        FocusManager.FocusedElement="{Binding ElementName=NameBox}"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RackCad.UI;component/Themes/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Larguero (componente)" FontSize="18" FontWeight="SemiBold" Foreground="#1F2933" />
            <TextBlock Text="Un larguero = un perfil + 2 ménsulas. Solo visual y para el BOM: aún no tiene bloque de AutoCAD."
                       Foreground="#9AA7B4" FontSize="11" Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Form -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Nombre" Foreground="#617080" FontSize="12" Margin="0,0,0,2" />
                <TextBox x:Name="NameBox" Margin="0,0,0,10" />

                <TextBlock Text="Perfil (larguero)" Foreground="#617080" FontSize="12" Margin="0,0,0,2" />
                <ComboBox x:Name="ProfileBox" DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                          SelectionChanged="Profile_Changed" Margin="0,0,0,10" />

                <TextBlock Text="Peralte" Foreground="#617080" FontSize="12" Margin="0,0,0,2" />
                <ComboBox x:Name="PeralteBox" SelectionChanged="Field_Changed" Margin="0,0,0,10" />

                <TextBlock Text="Longitud a corte (in)" Foreground="#617080" FontSize="12" Margin="0,0,0,2" />
                <TextBox x:Name="LengthBox" Text="96" LostFocus="Field_Changed" Margin="0,0,0,10" />

                <TextBlock Text="Ménsula" Foreground="#617080" FontSize="12" Margin="0,0,0,2" />
                <ComboBox x:Name="MensulaBox" DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                          SelectionChanged="Field_Changed" />
            </StackPanel>

            <!-- Preview -->
            <Border Grid.Column="1" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" CornerRadius="4">
                <Canvas x:Name="PreviewCanvas" ClipToBounds="True" Background="Transparent" SizeChanged="Preview_SizeChanged" />
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" x:Name="StatusText" Foreground="#617080" FontSize="12" Margin="0,10,0,0" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Ver lista de materiales" Style="{StaticResource SecondaryButtonStyle}" MinWidth="150" Margin="0,0,8,0" Click="ViewBom_Click" />
            <Button Content="Guardar en biblioteca" Style="{StaticResource PrimaryButtonStyle}" MinWidth="150" Margin="0,0,8,0" Click="Save_Click" />
            <Button Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" IsCancel="True" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
