<Window x:Class="RackCad.UI.RackFrameConfiguratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:RackCad.UI"
        Title="RACKCABECERA"
        Width="1320"
        Height="820"
        MinWidth="1160"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F6"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="/RackCad.UI;component/Themes/AppStyles.xaml" />
                </ResourceDictionary.MergedDictionaries>
            <Style x:Key="PanelBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="White" />
                <Setter Property="BorderBrush" Value="#D8DEE6" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="14" />
            </Style>

            <Style x:Key="HiddenDetailPanelStyle" TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Setter Property="Margin" Value="0,12,0,0" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#1F2933" />
            </Style>

            <Style x:Key="MutedTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#617080" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="PropertyLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#617080" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,0,12,10" />
            </Style>

            <Style x:Key="PropertyValueTextBoxStyle" TargetType="TextBox">
                <Setter Property="BorderBrush" Value="#C9D2DD" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="7,4" />
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="PropertyComboBoxStyle" TargetType="ComboBox">
                <Setter Property="BorderBrush" Value="#C9D2DD" />
                <Setter Property="Padding" Value="4,2" />
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="CompactButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="Margin" Value="0,0,8,8" />
                <Setter Property="MinWidth" Value="88" />
            </Style>

            <Style x:Key="CellTextBoxStyle" TargetType="TextBox">
                <Setter Property="BorderBrush" Value="#C9D2DD" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="CellComboBoxStyle" TargetType="ComboBox">
                <Setter Property="BorderBrush" Value="#C9D2DD" />
                <Setter Property="Padding" Value="4,2" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            </ResourceDictionary>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2933" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Configurador de cabecera"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Partir del estándar y modificar excepciones"
                               Foreground="#C7D0DA"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StandardBaselineId}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding StandardBaselineVersion, StringFormat=Versión {0}}"
                               Foreground="#C7D0DA"
                               FontSize="12"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0" />
                    <Border Background="#324456"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Right"
                            ToolTip="Muestra u oculta el editor detallado (horizontales, paneles, perfiles y excepciones). Apagado = configuración rápida.">
                        <CheckBox Content="Editor avanzado"
                                  IsChecked="{Binding IsAdvancedEditor, Mode=TwoWay}"
                                  Foreground="White"
                                  FontWeight="SemiBold"
                                  VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="MainScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="MainContentGrid"
              Margin="16"
              MinHeight="680"
              Height="{Binding ViewportHeight, ElementName=MainScrollViewer}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftColumn" Width="245" MinWidth="220" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition x:Name="CenterColumn" Width="*" MinWidth="600" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition x:Name="PreviewColumn" Width="318" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Grid.ColumnSpan="3"
                    Style="{StaticResource PanelBorderStyle}"
                    Visibility="{Binding IsSimpleEditor, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                        <TextBlock Text="Configuración rápida" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Define lo esencial y genera la cabecera. Activa &quot;Editor avanzado&quot; en la barra superior para ajustar horizontales, paneles, perfiles y excepciones en detalle."
                                   Style="{StaticResource MutedTextStyle}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,16" />

                        <TextBlock Text="Tipo de cabecera" Style="{StaticResource PropertyLabelStyle}" />
                        <ComboBox Style="{StaticResource PropertyComboBoxStyle}"
                                  ItemsSource="{Binding HeaderTemplateOptions}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding SelectedHeaderTemplate, Mode=TwoWay}" />

                        <TextBlock Text="Tipo de poste" Style="{StaticResource PropertyLabelStyle}" />
                        <ComboBox Style="{StaticResource PropertyComboBoxStyle}"
                                  ItemsSource="{Binding PostProfileOptions}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SimplePostCatalogId, Mode=TwoWay}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Alto (in)" Style="{StaticResource PropertyLabelStyle}" />
                                <TextBox Style="{StaticResource PropertyValueTextBoxStyle}"
                                         Text="{Binding SimpleHeightText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Fondo (in)" Style="{StaticResource PropertyLabelStyle}" />
                                <TextBox Style="{StaticResource PropertyValueTextBoxStyle}"
                                         Text="{Binding SimpleDepthText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                        </Grid>

                        <Button Content="Generar cabecera"
                                Click="ApplySimpleHeader_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Left"
                                MinWidth="150"
                                Margin="0,8,0,0" />

                        <Border Background="#F1F4F8"
                                BorderBrush="#D8DEE6"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Estado" FontWeight="SemiBold" Foreground="#415161" />
                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="{Binding StatusBrush}"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}"
                    Visibility="{Binding IsAdvancedEditor, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="LeftModelRow" Height="205" MinHeight="120" />
                        <RowDefinition Height="8" />
                        <RowDefinition x:Name="LeftValidationRow" Height="122" MinHeight="95" />
                        <RowDefinition Height="8" />
                        <RowDefinition x:Name="LeftExceptionsRow" Height="*" MinHeight="140" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Modelo" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Selecciona una parte para editar sus propiedades."
                                   Style="{StaticResource MutedTextStyle}"
                                   FontSize="12"
                                   Margin="0,4,0,12" />
                    </StackPanel>

                    <TreeView x:Name="ModelTree"
                              Grid.Row="1"
                              ItemsSource="{Binding NavigationItems}"
                              SelectedItemChanged="ModelTree_SelectedItemChanged"
                              BorderBrush="#D8DEE6"
                              BorderThickness="1"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type ui:ConfiguratorNavigationItem}"
                                                      ItemsSource="{Binding Children}">
                                <Border Padding="8,7">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#1F2933" />
                                        <TextBlock Text="{Binding Subtitle}" Foreground="#617080" FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    <GridSplitter Grid.Row="2"
                                  Height="8"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="#D8DEE6"
                                  ShowsPreview="True"
                                  ResizeBehavior="PreviousAndNext" />

                    <Border Grid.Row="3"
                            Background="{Binding HeightValidationBackground}"
                            BorderBrush="{Binding HeightValidationBrush}"
                            BorderThickness="1"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Validacion"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding HeightValidationBrush}" />
                            <TextBlock Text="{Binding HeightValidationMessage}"
                                       Foreground="#415161"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="0,5,0,0" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Objetivo" Foreground="#617080" FontSize="11" />
                                    <TextBlock Text="{Binding TargetHeightText}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Configurada" Foreground="#617080" FontSize="11" />
                                    <TextBlock Text="{Binding ConfiguredHeightText}" FontWeight="SemiBold" Foreground="{Binding HeightValidationBrush}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <GridSplitter Grid.Row="4"
                                  Height="8"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="#D8DEE6"
                                  ShowsPreview="True"
                                  ResizeBehavior="PreviousAndNext" />

                    <Grid Grid.Row="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="True">
                            <TextBlock Text="Excepciones" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding Exceptions.Count}"
                                       Foreground="#617080"
                                       FontWeight="SemiBold" />
                        </DockPanel>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding ExceptionSummary}"
                                   Style="{StaticResource MutedTextStyle}"
                                   FontSize="12"
                                   Margin="0,4,0,8" />

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding ExceptionGroups}"
                                 BorderBrush="#D8DEE6"
                                 BorderThickness="1"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E3E8EF"
                                            BorderThickness="0,0,0,1"
                                            Padding="8">
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock Text="{Binding TargetId, Mode=OneWay}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1F2933" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding CountText, Mode=OneWay}"
                                                           Foreground="#617080"
                                                           FontSize="10" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Changes}" Margin="0,5,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontSize="11"
                                                                   Foreground="#617080"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,2,0,0">
                                                            <Run Text="- " />
                                                            <Run Text="{Binding FieldName, Mode=OneWay}" />
                                                            <Run Text=": " />
                                                            <Run Text="{Binding StandardValue, Mode=OneWay}" />
                                                            <Run Text=" -> " />
                                                            <Run Text="{Binding OverrideValue, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D8DEE6"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"
                          Visibility="{Binding IsAdvancedEditor, Converter={StaticResource BoolToVis}}" />

            <Grid x:Name="CenterPanelGrid" Grid.Column="2"
                  Visibility="{Binding IsAdvancedEditor, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="CenterPropertiesRow" Height="150" MinHeight="115" />
                    <RowDefinition Height="8" />
                    <RowDefinition x:Name="CenterQuickRow" Height="90" MinHeight="72" />
                    <RowDefinition Height="8" />
                    <RowDefinition x:Name="CenterBulkRow" Height="80" MinHeight="65" />
                    <RowDefinition Height="8" />
                    <RowDefinition x:Name="CenterTablesRow" Height="*" MinHeight="368" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <StackPanel>
                                <TextBlock Text="{Binding ActiveDetailTitle}" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding ActiveDetailSubtitle}"
                                           Style="{StaticResource MutedTextStyle}"
                                           FontSize="12"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding SelectedSegmentSummary}"
                                       Foreground="#617080"
                                       FontSize="12"
                                       VerticalAlignment="Top" />
                        </DockPanel>

                        <Grid>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource HiddenDetailPanelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDetailKey}" Value="Header">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Plantilla base" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding TemplateSummary, Mode=OneWay}" IsReadOnly="True" Background="#F7F9FB" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Altura objetivo" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding HeightText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Fondo" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding DepthText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Unidades" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding Units, Mode=OneWay}" IsReadOnly="True" Background="#F7F9FB" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Inicio celosia (troquel)" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding CelosiaStartTroquelText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="Offset diag. inicio (troqueles)" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="3" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding DiagonalStartOffsetText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Offset diag. fin (troqueles)" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding DiagonalEndOffsetText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                </Grid>
                            </Border>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource HiddenDetailPanelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDetailKey}" Value="LeftPost">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Perfil" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding PostProfileOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding LeftPostCatalogId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Descripcion" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding LeftPostDescription, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Refuerzo" Style="{StaticResource PropertyLabelStyle}" />
                                    <CheckBox Grid.Row="1" Grid.Column="1" Content="Poste reforzado" IsChecked="{Binding LeftPostHasReinforcement, Mode=TwoWay}" Margin="0,3,0,10" />

                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Tipo refuerzo" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="4" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ReinforcementProfileOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding LeftPostReinforcementCatalogId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Placa asociada" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding BasePlateOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding LeftPlateCatalogId, Mode=TwoWay}" />
                                </Grid>
                            </Border>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource HiddenDetailPanelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDetailKey}" Value="RightPost">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Perfil" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding PostProfileOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding RightPostCatalogId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Descripcion" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding RightPostDescription, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Refuerzo" Style="{StaticResource PropertyLabelStyle}" />
                                    <CheckBox Grid.Row="1" Grid.Column="1" Content="Poste reforzado" IsChecked="{Binding RightPostHasReinforcement, Mode=TwoWay}" Margin="0,3,0,10" />

                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Tipo refuerzo" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="4" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ReinforcementProfileOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding RightPostReinforcementCatalogId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Placa asociada" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding BasePlateOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding RightPlateCatalogId, Mode=TwoWay}" />
                                </Grid>
                            </Border>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource HiddenDetailPanelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDetailKey}" Value="Segments">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Claro calculado" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding SelectedBracingSegment.ClearHeightText, Mode=OneWay}" IsReadOnly="True" Background="#F7F9FB" />

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Arreglo de panel" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="4" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding PatternOptions}" SelectedItem="{Binding SelectedBracingSegment.Pattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Cara de montaje" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="7" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding SideOptions}" SelectedItem="{Binding SelectedBracingSegment.SideMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

