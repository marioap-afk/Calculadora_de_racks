                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Derecho" Style="{StaticResource PropertyLabelStyle}" />
                                    <CheckBox Grid.Row="0" Grid.Column="4" Content="Con refuerzo" IsChecked="{Binding RightPostHasReinforcement, Mode=TwoWay}" Margin="0,3,0,10" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tipo izquierdo" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ReinforcementProfileOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding LeftPostReinforcementCatalogId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Tipo derecho" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="4" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ReinforcementProfileOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding RightPostReinforcementCatalogId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Altura refuerzo izq (in)" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding LeftPostReinforcementHeight, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=0.##}" ToolTip="Altura (LONGITUD) del refuerzo izquierdo desde la base. La celosía en esa zona se ancla al troquel del refuerzo." />

                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Altura refuerzo der (in)" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="2" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding RightPostReinforcementHeight, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=0.##}" ToolTip="Altura (LONGITUD) del refuerzo derecho desde la base. La celosía en esa zona se ancla al troquel del refuerzo." />
                                </Grid>
                            </Border>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource HiddenDetailPanelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDetailKey}" Value="Plates">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Placa izquierda" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding BasePlateOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding LeftPlateCatalogId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Placa derecha" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="4" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding BasePlateOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding RightPlateCatalogId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Punto izquierdo" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ConnectionPointOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding LeftPlateConnectionPointId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Punto derecho" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="4" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ConnectionPointOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding RightPlateConnectionPointId, Mode=TwoWay}" />
                                </Grid>
                            </Border>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource HiddenDetailPanelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDetailKey}" Value="Horizontals">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="Las horizontales son piezas fisicas independientes; los paneles se recalculan entre horizontales consecutivas."
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="145" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="145" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Horizontal" Style="{StaticResource PropertyLabelStyle}" />
                                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding SelectedHorizontal.Label, Mode=OneWay}" IsReadOnly="True" Background="#F7F9FB" />

                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Elevacion" Style="{StaticResource PropertyLabelStyle}" />
                                        <TextBox Grid.Row="0" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding SelectedHorizontal.ElevationText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Perfil" Style="{StaticResource PropertyLabelStyle}" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding HorizontalProfileOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding SelectedHorizontal.ProfileId, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Cantidad" Style="{StaticResource PropertyLabelStyle}" />
                                        <TextBox Grid.Row="1" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding SelectedHorizontal.Quantity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cara" Style="{StaticResource PropertyLabelStyle}" />
                                        <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding SideOptions}" SelectedItem="{Binding SelectedHorizontal.MountingFace, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="2" Grid.Column="3" Text="Estado" Style="{StaticResource PropertyLabelStyle}" />
                                        <ComboBox Grid.Row="2" Grid.Column="4" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding HorizontalStateOptions}" SelectedItem="{Binding SelectedHorizontal.State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <WrapPanel>
                                        <Button Style="{StaticResource CompactButtonStyle}" Content="Agregar horizontal" Click="AddHorizontal_Click" />
                                        <Button Style="{StaticResource CompactButtonStyle}" Content="Eliminar horizontal" IsEnabled="{Binding CanDeleteSelectedHorizontal}" Click="DeleteSelectedHorizontal_Click" />
                                        <Button Style="{StaticResource CompactButtonStyle}" Content="Duplicar horizontal" IsEnabled="{Binding CanDuplicateSelectedHorizontal}" Click="DuplicateSelectedHorizontal_Click" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource HiddenDetailPanelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDetailKey}" Value="Connections">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Punto inicial panel" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ConnectionPointOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding SelectedBracingSegment.StartConnectionPointId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Punto final panel" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="0" Grid.Column="4" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ConnectionPointOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding SelectedBracingSegment.EndConnectionPointId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Placa izquierda" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ConnectionPointOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding LeftPlateConnectionPointId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Placa derecha" Style="{StaticResource PropertyLabelStyle}" />
                                    <ComboBox Grid.Row="1" Grid.Column="4" Style="{StaticResource PropertyComboBoxStyle}" ItemsSource="{Binding ConnectionPointOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectedValue="{Binding RightPlateConnectionPointId, Mode=TwoWay}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Panel activo" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding SelectedSegmentSummary, Mode=OneWay}" IsReadOnly="True" Background="#F7F9FB" />
                                </Grid>
                            </Border>

                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource HiddenDetailPanelStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveDetailKey}" Value="Other">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Plantilla" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="0" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding TemplateSummary, Mode=OneWay}" IsReadOnly="True" Background="#F7F9FB" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Altura" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding HeightText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Fondo" Style="{StaticResource PropertyLabelStyle}" />
                                    <TextBox Grid.Row="1" Grid.Column="4" Style="{StaticResource PropertyValueTextBoxStyle}" Text="{Binding DepthText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                    </ScrollViewer>
                </Border>

                <GridSplitter Grid.Row="1"
                              Height="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="#D8DEE6"
                              ShowsPreview="True"
                              ResizeBehavior="PreviousAndNext" />

                <Border Grid.Row="2"
                        Background="#F7F9FB"
                        BorderBrush="#D8DEE6"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Edición rápida"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2933"
                                   Margin="0,0,0,8" />
                        <WrapPanel>
                            <Button Style="{StaticResource CompactButtonStyle}" Content="Agregar horizontal" Click="AddHorizontal_Click" />
                            <Button Style="{StaticResource CompactButtonStyle}" Content="Nuevo claro 44 in" Click="Add44Segment_Click" />
                            <Button Style="{StaticResource CompactButtonStyle}" Content="Nuevo claro 70 in" Click="Add70Segment_Click" />
                            <Button Style="{StaticResource CompactButtonStyle}" Content="Sin celosia" Click="QuickNoBracing_Click" />
                            <Button Style="{StaticResource CompactButtonStyle}" Content="Doble diagonal" Click="QuickDoubleBracing_Click" />
                        </WrapPanel>
                        <TextBlock Text="Herramientas de paneles y horizontales"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2933"
                                   Margin="0,4,0,8" />
                        <WrapPanel>
                            <Button Style="{StaticResource CompactButtonStyle}" Content="Eliminar horizontal" IsEnabled="{Binding CanDeleteSelectedHorizontal}" Click="DeleteSelectedHorizontal_Click" />
                            <Button Style="{StaticResource CompactButtonStyle}" Content="Duplicar horizontal" IsEnabled="{Binding CanDuplicateSelectedHorizontal}" Click="DuplicateSelectedHorizontal_Click" />
                            <Button Style="{StaticResource CompactButtonStyle}" Content="Dividir panel" IsEnabled="{Binding CanSplitSelectedSegment}" Click="SplitSelectedSegment_Click" />
                            <Button Style="{StaticResource CompactButtonStyle}" Content="Combinar paneles" IsEnabled="{Binding CanCombineSegments}" Click="CombineSelectedSegments_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <GridSplitter Grid.Row="3"
                              Height="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="#D8DEE6"
                              ShowsPreview="True"
                              ResizeBehavior="PreviousAndNext" />

                <Border Grid.Row="4"
                        Background="#F7F9FB"
                        BorderBrush="#D8DEE6"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="{Binding SelectedSegmentCountLabel}"
                                           Foreground="#617080"
                                           FontWeight="SemiBold" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding SelectedBracingSegment.StatusLabel, StringFormat=Activo: {0}, TargetNullValue=Activo: ninguno}"
                                           Foreground="{Binding SelectedBracingSegment.StatusBrush}" />
                            </DockPanel>

                            <WrapPanel Margin="0,10,0,0">
                                <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                          Width="140"
                                          Margin="0,0,8,8"
                                          ItemsSource="{Binding PatternOptions}"
                                          SelectedItem="{Binding BulkPattern, Mode=TwoWay}" />
                                <Button Style="{StaticResource CompactButtonStyle}" Content="Aplicar arreglo" Click="ApplyBulkPattern_Click" />

                                <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                          Width="110"
                                          Margin="12,0,8,8"
                                          ItemsSource="{Binding SideOptions}"
                                          SelectedItem="{Binding BulkSide, Mode=TwoWay}" />
                                <Button Style="{StaticResource CompactButtonStyle}" Content="Aplicar cara" Click="ApplyBulkSide_Click" />

                                <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                          Width="230"
                                          Margin="12,0,8,8"
                                          ItemsSource="{Binding DiagonalProfileOptions}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding BulkProfileId, Mode=TwoWay}" />
                                <Button Style="{StaticResource CompactButtonStyle}" Content="Aplicar perfil" Click="ApplyBulkProfile_Click" />
                            </WrapPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Restaurar panel activo"
                                IsEnabled="{Binding CanRestoreSelectedSegment}"
                                Padding="12,7"
                                Margin="16,0,0,0"
                                VerticalAlignment="Top"
                                Click="RestoreSelectedSegment_Click" />
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="5"
                              Height="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="#D8DEE6"
                              ShowsPreview="True"
                              ResizeBehavior="PreviousAndNext" />

                <Grid Grid.Row="6" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="HorizontalTableRow" Height="0.95*" MinHeight="180" />
                        <RowDefinition Height="8" />
                        <RowDefinition x:Name="PanelTableRow" Height="1.15*" MinHeight="180" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="HorizontalsGrid"
                              Grid.Row="0"
                              ItemsSource="{Binding Horizontals}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              SelectionChanged="HorizontalsGrid_SelectionChanged"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Horizontal" Binding="{Binding Label}" IsReadOnly="True" Width="90" />
                            <DataGridTextColumn Header="Estado" Binding="{Binding StatusLabel}" IsReadOnly="True" Width="95" />
                            <DataGridTemplateColumn Header="Elevacion" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Style="{StaticResource CellTextBoxStyle}"
                                                 Text="{Binding ElevationText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Perfil" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                                  ItemsSource="{Binding DataContext.HorizontalProfileOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding ProfileId, Mode=TwoWay}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Cantidad" Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="80" />
                            <DataGridTemplateColumn Header="Cara" Width="105">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                                  ItemsSource="{Binding DataContext.SideOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding MountingFace, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Estado físico" Width="125">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                                  ItemsSource="{Binding DataContext.HorizontalStateOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Notas" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Style="{StaticResource CellTextBoxStyle}"
                                                 Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="1"
                                  Height="8"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="#D8DEE6"
                                  ShowsPreview="True"
                                  ResizeBehavior="PreviousAndNext" />

                    <DataGrid x:Name="BracingSegmentsGrid"
                          Grid.Row="2"
                          ItemsSource="{Binding BracingSegments}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          SelectionChanged="BracingSegmentsGrid_SelectionChanged"
                          Margin="0,10,0,0"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="BorderBrush" Value="#E3E8EF" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsModified}" Value="True">
                                    <Setter Property="Background" Value="#FFF4D6" />
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DCEBFF" />
                                    <Setter Property="BorderBrush" Value="#2B6CB0" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Panel" Binding="{Binding Index}" IsReadOnly="True" Width="60" />
                        <DataGridTextColumn Header="Estado" Binding="{Binding StatusLabel}" IsReadOnly="True" Width="95" />
                        <DataGridTemplateColumn Header="Horizontal inf." Width="115">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Style="{StaticResource CellTextBoxStyle}"
                                             Text="{Binding LowerHorizontalId, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="#F7F9FB" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Horizontal sup." Width="115">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Style="{StaticResource CellTextBoxStyle}"
                                             Text="{Binding UpperHorizontalId, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="#F7F9FB" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Inicio" Binding="{Binding StartElevation, StringFormat={}{0:0.##} in}" IsReadOnly="True" Width="80" />
                        <DataGridTextColumn Header="Fin" Binding="{Binding EndElevation, StringFormat={}{0:0.##} in}" IsReadOnly="True" Width="80" />

                        <DataGridTemplateColumn Header="Claro" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Style="{StaticResource CellTextBoxStyle}"
                                             Text="{Binding ClearHeightText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="#F7F9FB" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Arreglo de panel" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                              ItemsSource="{Binding DataContext.PatternOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding Pattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Cara" Width="105">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                              ItemsSource="{Binding DataContext.SideOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding SideMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Direccion" Width="135">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                              ItemsSource="{Binding DataContext.DirectionOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding DiagonalDirection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Perfil" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Style="{StaticResource CellComboBoxStyle}"
                                              ItemsSource="{Binding DataContext.DiagonalProfileOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding BraceProfileId, Mode=TwoWay}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Punto inicial" Width="145">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Style="{StaticResource CellTextBoxStyle}"
                                             Text="{Binding StartConnectionPointId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Punto final" Width="145">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Style="{StaticResource CellTextBoxStyle}"
                                             Text="{Binding EndConnectionPointId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="3"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#D8DEE6"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="4" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Vista previa vertical" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Esquema WPF para revisar altura, claros, celosia, postes y refuerzos."
                                   Style="{StaticResource MutedTextStyle}"
                                   FontSize="12"
                                   Margin="0,4,0,12" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            BorderBrush="#D8DEE6"
                            BorderThickness="1"
                            Background="#FAFBFC">
                        <Canvas x:Name="PreviewCanvas"
                                Background="#FAFBFC"
                                SizeChanged="PreviewCanvas_SizeChanged" />
                    </Border>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Altura" Foreground="#617080" FontSize="11" />
                            <TextBlock Text="{Binding ConfiguredHeightText}" FontWeight="SemiBold" Foreground="{Binding HeightValidationBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Fondo" Foreground="#617080" FontSize="11" />
                            <TextBlock Text="{Binding Depth, StringFormat={}{0:0.##} in}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>

                    <WrapPanel Grid.Row="3" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                            <Rectangle Width="11" Height="11" Fill="#2B6CB0" Margin="0,2,4,0" />
                            <TextBlock Text="Front" Foreground="#617080" FontSize="11" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                            <Rectangle Width="11" Height="11" Fill="#C53030" Margin="0,2,4,0" />
                            <TextBlock Text="Rear" Foreground="#617080" FontSize="11" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
                            <Rectangle Width="11" Height="11" Fill="#805AD5" Margin="0,2,4,0" />
                            <TextBlock Text="Both" Foreground="#617080" FontSize="11" />
                        </StackPanel>
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#E9EEF3"
                BorderBrush="#D8DEE6"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{Binding StatusBrush}" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Border Background="#FFF4D6" BorderBrush="#E3E8EF" BorderThickness="1" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Fila modificada" Foreground="#617080" FontSize="11" Margin="5,0,16,0" VerticalAlignment="Center" />
                        <Border Background="#DCEBFF" BorderBrush="#2B6CB0" BorderThickness="1" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Fila seleccionada" Foreground="#617080" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Abrir proyecto"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="120"
                            Margin="0,0,8,0"
                            ToolTip="Abre una cabecera guardada (.rackcad.json)."
                            Click="OpenProject_Click" />
                    <Button Content="Guardar proyecto"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="130"
                            Margin="0,0,8,0"
                            ToolTip="Guarda la cabecera actual como archivo .rackcad.json."
                            Click="SaveProject_Click" />
                    <Button Content="Ver BOM"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="100"
                            Margin="0,0,8,0"
                            ToolTip="Muestra la lista de materiales (postes, placas, horizontales, diagonales) y permite exportarla a CSV."
                            Click="ViewBom_Click" />
                    <Button Content="Restaurar cabecera estándar"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="190"
                            Margin="0,0,8,0"
                            ToolTip="Vuelve a la cabecera estándar y descarta las modificaciones manuales."
                            Click="RestoreStandardFrameButton_Click" />
                    <Button Content="Restaurar layout predeterminado"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="185"
                            Margin="0,0,8,0"
                            ToolTip="Restaura el tamaño de paneles y tablas (no toca la configuración técnica)."
                            Click="ResetLayoutButton_Click" />
                    <Button Content="Insertar en AutoCAD"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Dibuja la cabecera lateral configurada en el dibujo activo de AutoCAD (vista lateral, basada en bloques)."
                            MinWidth="150"
                            Margin="0,0,8,0"
                            Click="InsertInAutoCad_Click" />
                    <Button Content="Cerrar"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="90"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
