<Window x:Class="RackCad.UI.RackDesignLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biblioteca de diseños"
        Height="480"
        Width="720"
        MinHeight="320"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="#F4F6F9">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RackCad.UI;component/Themes/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Biblioteca de diseños" FontSize="18" FontWeight="SemiBold" Foreground="#1F2933" />
            <TextBlock x:Name="FolderText" Foreground="#617080" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="Diseños de cabecera y sistema dinámico guardados como .rackcad.json. (El selectivo y la cama viven embebidos en el dibujo.)"
                       Foreground="#9AA7B4" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  x:Name="DesignsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowBackground="White"
                  AlternatingRowBackground="#F7F9FB"
                  BorderBrush="#D8DEE6"
                  BorderThickness="1"
                  SelectionMode="Single"
                  MouseDoubleClick="DesignsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Tipo" Binding="{Binding KindLabel}" Width="150" />
                <DataGridTextColumn Header="Modificado" Binding="{Binding Modified, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#617080" FontSize="11.5" Margin="0,0,12,0" />
            <Button Content="Abrir" Style="{StaticResource PrimaryButtonStyle}" MinWidth="110" Margin="0,0,8,0" Click="Open_Click" IsDefault="True" />
            <Button Content="Refrescar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" Margin="0,0,8,0" Click="Refresh_Click" />
            <Button Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" Click="Close_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
