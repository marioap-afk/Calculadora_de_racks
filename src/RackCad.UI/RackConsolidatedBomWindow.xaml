<Window x:Class="RackCad.UI.RackConsolidatedBomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lista de materiales del dibujo"
        Height="620"
        Width="820"
        MinHeight="420"
        MinWidth="620"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RackCad.UI;component/Themes/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Lista de materiales del dibujo" FontSize="18" FontWeight="SemiBold" Foreground="#1F2933" />
            <TextBlock x:Name="SummaryText" Foreground="#617080" FontSize="12" Margin="0,4,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Racks del dibujo (doble clic abre el BOM del rack)"
                   Foreground="#617080" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4" />

        <DataGrid Grid.Row="2"
                  x:Name="RacksGrid"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowBackground="White" AlternatingRowBackground="#F7F9FB"
                  BorderBrush="#D8DEE6" BorderThickness="1"
                  SelectionMode="Single" MouseDoubleClick="RacksGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Rack" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="140" />
                <DataGridTextColumn Header="Copias" Binding="{Binding Copies}" Width="70" />
                <DataGridTextColumn Header="Componentes" Binding="{Binding Componentes}" Width="110" />
                <DataGridTextColumn Header="Piezas" Binding="{Binding Piezas}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Text="Total del dibujo, por componente (clic para ver sus piezas · ×copias)"
                   Foreground="#617080" FontSize="12" FontWeight="SemiBold" Margin="0,12,0,4" />

        <DataGrid Grid.Row="4"
                  x:Name="TotalGrid"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowBackground="White" AlternatingRowBackground="#F7F9FB"
                  BorderBrush="#D8DEE6" BorderThickness="1"
                  SelectionMode="Single" RowDetailsVisibilityMode="VisibleWhenSelected">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Componente" Binding="{Binding Category}" Width="130" FontWeight="SemiBold" />
                <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="*" />
                <DataGridTextColumn Header="Longitud (in)" Binding="{Binding Length, StringFormat={}{0:0.##}}" Width="105">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,6,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Quantity}" Width="85">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,6,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Margin="24,4,8,10" Padding="10" Background="#F0F4F8" BorderBrush="#D8DEE6" BorderThickness="1" CornerRadius="3">
                        <StackPanel>
                            <TextBlock Text="Piezas (por unidad):" FontWeight="SemiBold" Foreground="#617080" FontSize="11" Margin="0,0,0,5" />
                            <DataGrid ItemsSource="{Binding Pieces}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                                      HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Pieza" Binding="{Binding Category}" Width="120" />
                                    <DataGridTextColumn Header="Perfil" Binding="{Binding ProfileId}" Width="200" />
                                    <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="*" />
                                    <DataGridTextColumn Header="Cant./u" Binding="{Binding Quantity}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right" />
                                                <Setter Property="Margin" Value="0,0,6,0" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Exportar Excel" Style="{StaticResource PrimaryButtonStyle}" MinWidth="120" Margin="0,0,8,0" Click="ExportExcel_Click" />
            <Button Content="Exportar CSV" Style="{StaticResource SecondaryButtonStyle}" MinWidth="120" Margin="0,0,8,0" Click="ExportCsv_Click" />
            <Button Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" IsCancel="True" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
