<Window x:Class="RackCad.UI.RackFlowBedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cama de rodamiento - vista lateral"
        Height="640"
        Width="1080"
        MinHeight="520"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F6"
        FontFamily="Segoe UI"
        FocusManager.FocusedElement="{Binding ElementName=NameBox}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RackCad.UI;component/Themes/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: inputs -->
        <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Rack" Style="{StaticResource SectionTitle}" Margin="0,0,0,2" />
                    <TextBlock Text="Nombre (Rack A)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="NameBox" Style="{StaticResource FieldBox}"
                             ToolTip="Nombre del rack como lo ve el cliente. Se guarda con el bloque para reabrirlo y editarlo." />

                    <TextBlock Text="Cama" Style="{StaticResource SectionTitle}" />

                    <TextBlock Text="Tipo de cama" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="BedTypeBox" SelectionChanged="Input_Changed"
                              ToolTip="Dinámica: lleva frenos según el fondo de tarima. Pushback: sin frenos; el fondo de tarima no aplica.">
                        <ComboBoxItem Content="Dinámica" Tag="Dynamic" IsSelected="True" />
                        <ComboBoxItem Content="Pushback" Tag="Pushback" />
                    </ComboBox>

                    <TextBlock Text="Rodillo" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="RollerBox" SelectedValuePath="Id" DisplayMemberPath="DisplayName" SelectionChanged="Input_Changed"
                              ToolTip="Rodillo del catálogo. Su diámetro define el paso automático (1.9&quot;→2&quot;, 2.5&quot;→3&quot;)." />

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Fondo de cama (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="LaneDepthBox" Style="{StaticResource FieldBox}" Text="96" LostFocus="NumericBox_LostFocus"
                                     ToolTip="Profundidad total del carril en pulgadas: define el largo del riel y cuántos rodillos caben." />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="PalletDepthLabel" Text="Fondo de tarima (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="PalletDepthBox" Style="{StaticResource FieldBox}" Text="48" LostFocus="NumericBox_LostFocus"
                                     ToolTipService.ShowOnDisabled="True"
                                     ToolTip="Fondo de la tarima (in). Solo aplica a cama Dinámica: define la posición de los frenos. En Pushback no se usa." />
                        </StackPanel>
                    </Grid>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Actualizar vista" Click="Update_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,12,0" IsDefault="True"
                                ToolTip="Recalcula la cama con los datos capturados (Enter)." />
                        <CheckBox x:Name="AdvancedToggle" Content="Avanzado" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2B6CB0"
                                  Checked="AdvancedToggle_Changed" Unchecked="AdvancedToggle_Changed"
                                  ToolTip="Opciones finas: paso de rodillo." />
                    </WrapPanel>

                    <StackPanel x:Name="AdvancedPanel" Visibility="Collapsed">
                        <TextBlock Text="Paso de rodillo (in)" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="RollerPitchBox" Style="{StaticResource FieldBox}" LostFocus="NumericBox_LostFocus"
                                 ToolTip="Vacío = el mínimo por diámetro (1.9&quot;→2&quot;, 2.5&quot;→3&quot;)." />
                    </StackPanel>

                    <TextBlock x:Name="SummaryText" Foreground="#1F2933" FontSize="12" TextWrapping="Wrap" Margin="0,14,0,0" />
                    <TextBlock x:Name="StatusText" Foreground="#617080" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right: lateral preview -->
        <Border Grid.Row="0" Grid.Column="2" Background="White" BorderBrush="#D8DEE6" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="10,8">
                    <TextBlock Text="Vista lateral (X = fondo de cama). El riel arranca en el tope; los rodillos van al paso, el freno entre rodillos."
                               Foreground="#617080" FontSize="11" TextWrapping="Wrap" />
                    <WrapPanel Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="14" Height="14" CornerRadius="7" BorderBrush="#3DC986" BorderThickness="2" Margin="0,0,5,0" />
                            <TextBlock Text="rodillo" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="16" Height="16" CornerRadius="8" BorderBrush="#5B8DEF" BorderThickness="2" Margin="0,0,5,0" />
                            <TextBlock Text="freno" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="10" Height="14" Background="#FF6B6B" Margin="0,0,5,0" />
                            <TextBlock Text="tope" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="18" Height="6" BorderBrush="#CFDBE8" BorderThickness="1" Margin="0,3,5,0" />
                            <TextBlock Text="riel" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
                <Canvas x:Name="PreviewCanvas" Grid.Row="1" Background="#0E1B2A" ClipToBounds="True" SizeChanged="PreviewCanvas_SizeChanged" />
            </Grid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Lista de materiales" Style="{StaticResource SecondaryButtonStyle}" MinWidth="140" Margin="0,0,8,0"
                    ToolTip="Lista de materiales de la cama (riel, tope, rodillos, frenos)." Click="ShowBom_Click" />
            <Button Content="Guardar en biblioteca" Style="{StaticResource SecondaryButtonStyle}" MinWidth="150" Margin="0,0,8,0"
                    ToolTip="Guarda esta cama como archivo reutilizable en la biblioteca de diseños." Click="SaveToLibrary_Click" />
            <Button x:Name="InsertButton" Content="Insertar en AutoCAD" Style="{StaticResource PrimaryButtonStyle}" MinWidth="160" Margin="0,0,8,0"
                    ToolTipService.ShowOnDisabled="True"
                    ToolTip="Dibuja la cama en el dibujo activo de AutoCAD (vista lateral)." Click="InsertInAutoCad_Click" />
            <Button Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" Click="Close_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
