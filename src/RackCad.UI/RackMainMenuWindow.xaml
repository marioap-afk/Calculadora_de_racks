<Window x:Class="RackCad.UI.RackMainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RackCad"
        Height="760"
        Width="560"
        MinHeight="600"
        MinWidth="460"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RackCad.UI;component/Themes/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <!-- Card-style option button. -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2B6CB0" />
                                <Setter TargetName="bd" Property="Background" Value="#F0F6FC" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OptionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#1F2933" />
        </Style>

        <Style x:Key="OptionCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#617080" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2933" Padding="24,18">
            <StackPanel>
                <TextBlock Text="RackCad" FontSize="24" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Text="Selecciona qué deseas diseñar" Foreground="#C7D0DA" FontSize="13" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8">
                <Button Style="{StaticResource MenuButton}" Click="DesignSelective_Click">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar sistema selectivo" />
                        <TextBlock Style="{StaticResource OptionCaption}" Text="Vista frontal: cabeceras (postes) + largueros por nivel." />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButton}" Click="DesignDynamic_Click">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar sistema dinámico (Pallet Flow)" />
                        <TextBlock Style="{StaticResource OptionCaption}" Text="Vista lateral preliminar; usa cabeceras como componentes." />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButton}" Click="DesignHeader_Click">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar cabecera" />
                        <TextBlock Style="{StaticResource OptionCaption}" Text="Configurador de cabeceras (componente)." />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButton}" Click="DesignFlowBed_Click">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar cama de rodamiento" />
                        <TextBlock Style="{StaticResource OptionCaption}" Text="Riel, rodillos, frenos y tope (dinámica o pushback); vista lateral." />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButton}" Click="OpenDesignLibrary_Click">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionTitle}" Text="Abrir de la biblioteca de diseños" />
                        <TextBlock Style="{StaticResource OptionCaption}" Text="Reabre un diseño de cabecera o sistema dinámico guardado con nombre." />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButton}" IsEnabled="False">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar drive-in" />
                        <TextBlock Style="{StaticResource OptionCaption}" Foreground="#9AA7B4" Text="Próximamente." />
                    </StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#E9EEF3" BorderBrush="#D8DEE6" BorderThickness="0,1,0,0" Padding="24,12">
            <StackPanel>
                <TextBlock Text="Biblioteca de bloques (.dwg)" FontSize="11.5" FontWeight="SemiBold" Foreground="#415161" />
                <TextBlock Text="De aquí se importan los bloques que falten en el dibujo activo." FontSize="10.5" Foreground="#617080" Margin="0,2,0,0" />
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="LibraryPathBox" Grid.Column="0" IsReadOnly="True" VerticalContentAlignment="Center"
                             Padding="6,4" BorderBrush="#C9D2DD" Background="White"
                             ToolTip="Ruta del DWG con las definiciones de bloque. Se guarda y se usa en todas las inserciones." />
                    <Button Grid.Column="2" Content="Examinar…" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="14,6" Click="BrowseLibrary_Click" />
                    <Button Grid.Column="4" Content="Restablecer" Style="{StaticResource SecondaryButtonStyle}" MinWidth="0" Padding="14,6"
                            ToolTip="Vuelve a la ruta predeterminada (junto a los catálogos)." Click="ResetLibrary_Click" />
                </Grid>
                <Button Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="96" HorizontalAlignment="Right" Margin="0,12,0,0" Click="Close_Click" IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
