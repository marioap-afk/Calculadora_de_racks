<Window x:Class="RackCad.UI.RackMainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RackCad"
        Height="520"
        Width="560"
        MinHeight="460"
        MinWidth="460"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F6"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Card-style option button. -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2B6CB0" />
                                <Setter TargetName="bd" Property="Background" Value="#F0F6FC" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OptionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#1F2933" />
        </Style>

        <Style x:Key="OptionCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#617080" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Foreground" Value="#2D3748" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#C9D2DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EDF2F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2933" Padding="24,18">
            <StackPanel>
                <TextBlock Text="RackCad" FontSize="24" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Text="Selecciona qué deseas diseñar" Foreground="#C7D0DA" FontSize="13" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,20,24,8">
            <Button Style="{StaticResource MenuButton}" Click="DesignHeader_Click">
                <StackPanel>
                    <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar cabecera" />
                    <TextBlock Style="{StaticResource OptionCaption}" Text="Configurador de cabeceras (componente)." />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuButton}" Click="DesignDynamic_Click">
                <StackPanel>
                    <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar sistema dinámico (Pallet Flow)" />
                    <TextBlock Style="{StaticResource OptionCaption}" Text="Vista lateral preliminar; usa cabeceras como componentes." />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuButton}" Click="DesignFlowBed_Click">
                <StackPanel>
                    <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar cama de rodamiento" />
                    <TextBlock Style="{StaticResource OptionCaption}" Text="Riel, rodillos, frenos y tope (dinámica o pushback); vista lateral." />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuButton}" IsEnabled="False">
                <StackPanel>
                    <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar sistema selectivo" />
                    <TextBlock Style="{StaticResource OptionCaption}" Foreground="#9AA7B4" Text="Próximamente." />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuButton}" IsEnabled="False">
                <StackPanel>
                    <TextBlock Style="{StaticResource OptionTitle}" Text="Diseñar drive-in" />
                    <TextBlock Style="{StaticResource OptionCaption}" Foreground="#9AA7B4" Text="Próximamente." />
                </StackPanel>
            </Button>
        </StackPanel>

        <Border Grid.Row="2" Background="#E9EEF3" BorderBrush="#D8DEE6" BorderThickness="0,1,0,0" Padding="24,12">
            <Button Content="Cerrar" Style="{StaticResource CloseButton}" HorizontalAlignment="Right" Click="Close_Click" />
        </Border>
    </Grid>
</Window>
