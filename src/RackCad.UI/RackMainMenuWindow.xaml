<Window x:Class="RackCad.UI.RackMainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RackCad"
        Height="460"
        Width="520"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="RackCad" FontSize="24" FontWeight="SemiBold" Foreground="#1F2933" />
            <TextBlock Text="Selecciona que deseas disenar." Foreground="#617080" FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Button Style="{StaticResource MenuButton}" Click="DesignHeader_Click">
                <StackPanel>
                    <TextBlock Text="Disenar cabecera" FontWeight="SemiBold" />
                    <TextBlock Text="Configurador de cabeceras (componente)." Foreground="#617080" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuButton}" Click="DesignDynamic_Click">
                <StackPanel>
                    <TextBlock Text="Disenar sistema dinamico (Pallet Flow)" FontWeight="SemiBold" />
                    <TextBlock Text="Vista lateral preliminar; usa cabeceras como componentes." Foreground="#617080" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuButton}" IsEnabled="False">
                <StackPanel>
                    <TextBlock Text="Disenar sistema selectivo" FontWeight="SemiBold" />
                    <TextBlock Text="Proximamente." Foreground="#9AA7B4" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource MenuButton}" IsEnabled="False">
                <StackPanel>
                    <TextBlock Text="Disenar drive-in" FontWeight="SemiBold" />
                    <TextBlock Text="Proximamente." Foreground="#9AA7B4" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cerrar" MinWidth="90" Padding="14,7" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
