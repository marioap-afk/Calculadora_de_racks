<Window x:Class="RackCad.UI.RackSelectiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rack selectivo - vista frontal"
        Height="660"
        Width="1120"
        MinHeight="540"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F6"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RackCad.UI;component/Themes/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: inputs -->
        <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Cabecera" Style="{StaticResource SectionTitle}" Margin="0,0,0,2" />
                    <TextBlock Text="Poste" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="PostBox" SelectedValuePath="Id" DisplayMemberPath="DisplayName" />
                    <TextBlock Text="Peralte poste (in)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="PostPeralteBox" Style="{StaticResource FieldBox}" Text="3" />

                    <TextBlock Text="Larguero" Style="{StaticResource SectionTitle}" />
                    <ComboBox x:Name="BeamBox" SelectedValuePath="Id" DisplayMemberPath="DisplayName" />
                    <TextBlock Text="Peralte larguero (in)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="BeamPeralteBox" Style="{StaticResource FieldBox}" Text="4" />

                    <TextBlock Text="Tarima" Style="{StaticResource SectionTitle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Frente (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="FrenteBox" Style="{StaticResource FieldBox}" Text="40" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Alto (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="AltoBox" Style="{StaticResource FieldBox}" Text="60" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Tarimas por nivel" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="PalletCountBox" Style="{StaticResource FieldBox}" Text="2" />

                    <TextBlock Text="Tramo" Style="{StaticResource SectionTitle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Cantidad de bahías" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="BayCountBox" Style="{StaticResource FieldBox}" Text="2" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Niveles" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="LevelsBox" Style="{StaticResource FieldBox}" Text="4" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="1er nivel (in)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="FirstLevelBox" Style="{StaticResource FieldBox}" Text="6" />

                    <TextBlock Text="Tolerancias" Style="{StaticResource SectionTitle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Horizontal (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="ToleranceBox" Style="{StaticResource FieldBox}" Text="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Holgura vertical (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="ClearanceBox" Style="{StaticResource FieldBox}" Text="6" />
                        </StackPanel>
                    </Grid>

                    <Button Content="Actualizar vista" Click="Update_Click" Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left" Margin="0,14,0,0" IsDefault="True"
                            ToolTip="Recalcula el selectivo con los datos capturados (Enter)." />

                    <TextBlock x:Name="SummaryText" Foreground="#1F2933" FontSize="12" TextWrapping="Wrap" Margin="0,14,0,0" />
                    <TextBlock x:Name="StatusText" Foreground="#617080" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right: frontal preview -->
        <Border Grid.Row="0" Grid.Column="2" Background="White" BorderBrush="#D8DEE6" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="10,8">
                    <TextBlock Text="Vista frontal (X = ancho del tramo, Y = altura). Postes verticales (cabeceras) + largueros por nivel."
                               Foreground="#617080" FontSize="11" TextWrapping="Wrap" />
                    <WrapPanel Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="4" Height="14" Background="#3DC986" Margin="0,0,5,0" />
                            <TextBlock Text="poste (cabecera)" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Border Width="16" Height="5" Background="#E08A2B" Margin="0,4,5,0" />
                            <TextBlock Text="larguero" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="14" Height="6" Background="#B7C3CF" Margin="0,3,5,0" />
                            <TextBlock Text="placa base" Foreground="#617080" FontSize="10.5" />
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
                <Canvas x:Name="PreviewCanvas" Grid.Row="1" Background="#0E1B2A" ClipToBounds="True" SizeChanged="PreviewCanvas_SizeChanged" />
            </Grid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Insertar en AutoCAD" Style="{StaticResource PrimaryButtonStyle}" MinWidth="160" Margin="0,0,8,0"
                    ToolTip="Dibuja el selectivo (postes + largueros) en el dibujo activo de AutoCAD (vista frontal)." Click="InsertInAutoCad_Click" />
            <Button Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" Click="Close_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
