<Window x:Class="RackCad.UI.RackSelectiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rack selectivo - editor avanzado (vista frontal)"
        Height="740"
        Width="1300"
        MinHeight="600"
        MinWidth="1060"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F6"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RackCad.UI;component/Themes/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="342" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: global settings + selected-cell editor -->
        <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Rack" Style="{StaticResource SectionTitle}" Margin="0,0,0,2" />
                    <TextBlock Text="Nombre (Rack A)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="NameBox" Style="{StaticResource FieldBox}"
                             ToolTip="Nombre del rack como lo ve el cliente. Se guarda con el bloque para poder reabrirlo y editarlo." />

                    <TextBlock Text="Anotaciones y dibujo" Style="{StaticResource SectionTitle}" />
                    <CheckBox x:Name="DrawBasePlateCheck" Content="Dibujar placa base" IsChecked="True" Margin="0,4,0,0"
                              Foreground="#415161" Checked="DrawToggle_Changed" Unchecked="DrawToggle_Changed"
                              ToolTip="Dibuja las placas base bajo los postes (frontal y planta)." />
                    <CheckBox x:Name="NumberFrontsCheck" Content="Numerar frentes" Margin="0,4,0,0" Foreground="#415161"
                              ToolTip="Numera los frentes/postes. (El dibujo del texto llega en una próxima versión; la opción se guarda.)" />
                    <CheckBox x:Name="NumberLevelsCheck" Content="Numerar niveles" Margin="0,4,0,0" Foreground="#415161"
                              ToolTip="Numera los niveles de carga. (El dibujo del texto llega en una próxima versión; la opción se guarda.)" />
                    <CheckBox x:Name="DrawRackNameCheck" Content="Colocar nombre de rack" Margin="0,4,0,0" Foreground="#415161"
                              ToolTip="Dibuja el nombre del rack como texto. (El dibujo del texto llega en una próxima versión; la opción se guarda.)" />
                    <TextBlock Text="La numeración y el nombre se guardan ahora; su dibujo (texto) llega en una próxima versión."
                               Foreground="#8B98A6" FontSize="10.5" TextWrapping="Wrap" Margin="0,3,0,0" />

                    <TextBlock Text="Cabecera" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Poste" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="PostBox" SelectedValuePath="Id" DisplayMemberPath="DisplayName" />
                    <TextBlock Text="Peralte poste (in)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="PostPeralteBox" Style="{StaticResource FieldBox}" Text="3" />

                    <TextBlock Text="Cabecera por poste (opcional)" Style="{StaticResource FieldLabel}" Margin="0,6,0,0" Foreground="#8B98A6" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PostSelectBox" Grid.Column="0" SelectionChanged="PostSelect_Changed" />
                        <Button x:Name="CustomizePostButton" Grid.Column="2" Content="Personalizar" Click="CustomizePost_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="Abre el configurador de cabeceras para este poste (p. ej. peralte de placa)." />
                    </Grid>
                    <TextBlock Text="Peralte de este poste (in)" Style="{StaticResource FieldLabel}" Margin="0,4,0,0" />
                    <TextBox x:Name="PostPeralteOverrideBox" Style="{StaticResource FieldBox}" LostFocus="PostPeralteOverride_LostFocus"
                             ToolTip="Peralte solo del poste seleccionado. Déjalo vacío para usar el peralte global de arriba." />
                    <TextBlock x:Name="PostCabeceraStatus" Foreground="#617080" FontSize="10.5" TextWrapping="Wrap" Margin="0,3,0,0" />
                    <Button Content="Restablecer poste" Click="ResetPost_Click" Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left" Margin="0,4,0,0"
                            ToolTip="Quita la cabecera personalizada de este poste (vuelve a la del tramo)." />

                    <TextBlock Text="Tramo" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Frentes" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="BayCountBox" Style="{StaticResource FieldBox}" Text="2" />
                    <TextBlock Text="Los niveles, la altura y 'larguero a piso' se ajustan por frente en el encabezado de la matriz. El piso arranca en 0."
                               Foreground="#8B98A6" FontSize="10.5" TextWrapping="Wrap" Margin="0,4,0,0" />

                    <TextBlock Text="Tolerancias" Style="{StaticResource SectionTitle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Horizontal (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="ToleranceBox" Style="{StaticResource FieldBox}" Text="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Holgura vertical (in)" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="ClearanceBox" Style="{StaticResource FieldBox}" Text="6" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Elevación larguero a piso (in)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="FloorRiseBox" Style="{StaticResource FieldBox}" Text="4" />
                    <TextBlock Text="Fondo de tarima (in)" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="FondoBox" Style="{StaticResource FieldBox}" Text="48"
                             ToolTip="Profundidad de la tarima; define el fondo de las cabeceras en la vista lateral." />

                    <!-- Sin IsDefault: como botón default, Enter en CUALQUIER caja de la ventana (editor de celda,
                         alturas por frente) lo disparaba y LoadCellEditor revertía lo recién tecleado. -->
                    <Button Content="Actualizar tramo" Click="Update_Click" Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left" Margin="0,12,0,0"
                            ToolTip="Aplica frentes/niveles/tolerancias y recalcula." />

                    <Border Background="#F1F5F9" BorderBrush="#D8DEE6" BorderThickness="1" Margin="0,14,0,0" Padding="12">
                        <StackPanel>
                            <TextBlock x:Name="CellHeader" Text="Celda seleccionada" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                            <TextBlock Text="Larguero" Style="{StaticResource FieldLabel}" />
                            <ComboBox x:Name="CellBeamBox" SelectedValuePath="Id" DisplayMemberPath="DisplayName" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Frente tarima (in)" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="FrenteBox" Style="{StaticResource FieldBox}" Text="40" />
                                    <TextBlock Text="Tarimas por nivel" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="PalletCountBox" Style="{StaticResource FieldBox}" Text="2" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Alto tarima (in)" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="AltoBox" Style="{StaticResource FieldBox}" Text="60" />
                                    <TextBlock Text="Peralte larguero (in)" Style="{StaticResource FieldLabel}" />
                                    <ComboBox x:Name="BeamPeralteCombo" Margin="0,2,0,6"
                                              ToolTip="Peraltes permitidos por el larguero seleccionado (del catálogo)." />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Manual (opcional · vacío = auto)" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"
                                       Foreground="#8B98A6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Long. larguero (in)" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="BeamLenBox" Style="{StaticResource FieldBox}"
                                             ToolTip="Longitud del larguero (A corte). Vacío = automático. El frente usa el nivel más largo." />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Claro debajo (in)" Style="{StaticResource FieldLabel}" />
                                    <TextBox x:Name="ClearBox" Style="{StaticResource FieldBox}"
                                             ToolTip="Claro/separación debajo de este larguero. Vacío = automático. Se ajusta al troquel." />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Aplicar a:" Style="{StaticResource FieldLabel}" Margin="0,6,0,2" />
                            <WrapPanel>
                                <Button Content="Celda" Click="ApplyCell_Click" Style="{StaticResource SecondaryButtonStyle}" MinWidth="66" Margin="0,0,6,6"
                                        ToolTip="Aplica los valores a la celda seleccionada." />
                                <Button Content="Nivel" Click="ApplyRow_Click" Style="{StaticResource SecondaryButtonStyle}" MinWidth="60" Margin="0,0,6,6"
                                        ToolTip="Aplica a todo el nivel (misma fila, todos los frentes)." />
                                <Button Content="Frente" Click="ApplyColumn_Click" Style="{StaticResource SecondaryButtonStyle}" MinWidth="72" Margin="0,0,6,6"
                                        ToolTip="Aplica a todo el frente (misma columna, todos los niveles)." />
                                <Button Content="Todas" Click="ApplyAll_Click" Style="{StaticResource SecondaryButtonStyle}" MinWidth="66" Margin="0,0,0,6"
                                        ToolTip="Aplica a todas las celdas del tramo." />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="SummaryText" Foreground="#1F2933" FontSize="12" TextWrapping="Wrap" Margin="0,14,0,0" />
                    <TextBlock x:Name="StatusText" Foreground="#617080" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right: matrix (top) + frontal preview (bottom) -->
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#D8DEE6" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Matriz frente × nivel — clic en una celda para editarla. En cada encabezado de frente ajusta niveles (−/+), altura y 'Piso' (larguero a piso). Nivel 1 abajo."
                               Foreground="#617080" FontSize="11" TextWrapping="Wrap" Margin="10,8,10,0" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="230">
                        <Grid x:Name="MatrixGrid" Margin="10,8,10,10" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="White" BorderBrush="#D8DEE6" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="10,8">
                        <TextBlock Text="Vista frontal (X = ancho del tramo, Y = altura). Postes (cabeceras) + largueros por nivel."
                                   Foreground="#617080" FontSize="11" TextWrapping="Wrap" />
                        <WrapPanel Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                <Border Width="4" Height="14" Background="#3DC986" Margin="0,0,5,0" />
                                <TextBlock Text="poste (cabecera)" Foreground="#617080" FontSize="10.5" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                <Border Width="16" Height="5" Background="#E08A2B" Margin="0,4,5,0" />
                                <TextBlock Text="larguero" Foreground="#617080" FontSize="10.5" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="14" Height="6" Background="#B7C3CF" Margin="0,3,5,0" />
                                <TextBlock Text="placa base" Foreground="#617080" FontSize="10.5" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                    <Canvas x:Name="PreviewCanvas" Grid.Row="1" Background="#0E1B2A" ClipToBounds="True" SizeChanged="PreviewCanvas_SizeChanged" />
                </Grid>
            </Border>
        </Grid>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="UpdateButton" Content="Actualizar" Style="{StaticResource PrimaryButtonStyle}" MinWidth="120" Margin="0,0,8,0"
                    ToolTipService.ShowOnDisabled="True"
                    ToolTip="Redibuja en sitio las vistas ya dibujadas de este rack con tus cambios (no inserta nada). Disponible al editar con RACKEDITAR." Click="UpdateExisting_Click" />
            <Button Content="Lista de materiales" Style="{StaticResource SecondaryButtonStyle}" MinWidth="150" Margin="0,0,8,0"
                    ToolTip="Genera el BOM (postes, placas, largueros y ménsulas) del selectivo actual." Click="ShowBom_Click" />
            <Button Content="Insertar frontal" Style="{StaticResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,0"
                    ToolTip="Inserta una VISTA FRONTAL (postes + largueros) enlazada a este rack (mismo GUID) y refresca las demás vistas." Click="InsertFrontal_Click" />
            <Button x:Name="InsertLateralButton" Content="Insertar lateral" Style="{StaticResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,0"
                    ToolTipService.ShowOnDisabled="True"
                    ToolTip="Inserta una VISTA LATERAL (un corte de poste) enlazada a este rack (mismo GUID) y refresca las demás vistas." Click="InsertLateral_Click" />
            <Button x:Name="InsertPlantaButton" Content="Insertar planta" Style="{StaticResource SecondaryButtonStyle}" MinWidth="130" Margin="0,0,8,0"
                    ToolTipService.ShowOnDisabled="True"
                    ToolTip="Inserta una VISTA PLANTA (superior) enlazada a este rack (mismo GUID) y refresca las demás vistas." Click="InsertPlanta_Click" />
            <Button Content="Cerrar" Style="{StaticResource SecondaryButtonStyle}" MinWidth="90" Click="Close_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
