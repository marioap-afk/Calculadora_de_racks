<?xml version="1.0" encoding="utf-8"?>
<!--
  AutoCAD Autoloader manifest. Put the whole "RackCad.bundle" folder (this file + Contents\)
  in an ApplicationPlugins folder, e.g. %AppData%\Autodesk\ApplicationPlugins\, and AutoCAD
  loads RackCad automatically at startup (no NETLOAD). Requires AutoCAD 2025+ (.NET 8 = R25.0).
  The build assembles Contents\ (the 4 DLLs + catalogs\) next to the plugin output.
-->
<ApplicationPackage
    SchemaVersion="1.0"
    ProductType="Application"
    AutodeskProduct="AutoCAD"
    Name="RackCad"
    AppVersion="1.0.0"
    Description="Diseño de racks industriales (selectivo, dinámico, cabecera, cama de rodamiento) en AutoCAD."
    Author="RackCad">
  <CompanyDetails Name="RackCad" />
  <Components Description="RackCad .NET 8 plugin (AutoCAD 2025+)">
    <RuntimeRequirements OS="Win64" Platform="AutoCAD*" SeriesMin="R25.0" />
    <ComponentEntry
        AppName="RackCad"
        Version="1.0.0"
        ModuleName="./Contents/RackCad.Plugin.dll"
        LoadOnAutoCADStartup="True"
        AppDescription="Comandos: RACKCAD, RACKSELECTIVO, RACKSISTEMADINAMICO, RACKCABECERA, QUICKCABECERA, QUICKCAMA, RACKEDITAR, RACKDUPLICAR, RACKLISTA." />
  </Components>
</ApplicationPackage>
