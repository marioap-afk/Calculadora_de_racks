{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RackCad rack frame catalog",
  "type": "object",
  "required": ["catalogId", "version", "units", "postProfiles", "horizontalProfiles", "diagonalProfiles", "basePlates", "connectionPoints"],
  "properties": {
    "catalogId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "units": { "type": "string", "enum": ["in", "mm"] },
    "postProfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/catalogEntry" }
    },
    "horizontalProfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/catalogEntry" }
    },
    "diagonalProfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/catalogEntry" }
    },
    "basePlates": {
      "type": "array",
      "items": { "$ref": "#/$defs/catalogEntry" }
    },
    "connectionPoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/connectionPoint" }
    }
  },
  "$defs": {
    "catalogEntry": {
      "type": "object",
      "required": ["id", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "attributes": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "connectionPoint": {
      "type": "object",
      "required": ["id", "description", "offsetX", "offsetY"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "offsetX": { "type": "number" },
        "offsetY": { "type": "number" }
      }
    }
  }
}
